{
  "inlcude": [
    "src/**/*.js"
  ],
  "exclude": [
    "test/**/*.*",
    "types/**/*.*",
    "resources/**/*.*",
    "docs/**/*.*",
    "node_modules/**/*.*",
    "coverage/**/*.*"
  ],
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["src/*"]
    },
    "baseUrl": "."
  }
}