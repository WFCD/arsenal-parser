{
  "name": "@wfcd/arsenal-parser",
  "version": "0.0.1",
  "description": "Parser for Digital Extreme's Twitch Arsenal Extension data",
  "keywords": [
    "warframe",
    "parser",
    "twitch",
    "arsenal"
  ],
  "repository": "https://github.com/WFCD/arsenal-parser",
  "license": "MIT",
  "author": "NicksWorld",
  "contributors": [
    "TobiTenno <tobiah@pm.me>"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/ArsenalParser.js",
      "types": "./types/src/ArsenalParser.d.ts"
    }
  },
  "main": "src/ArsenalParser.js",
  "types": "./types/src/ArsenalParser.d.ts",
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "types"
  ],
  "scripts": {
    "build": "tsdown",
    "build:docs": "typedoc",
    "coverage": "npm test && nyc report --reporter=text-lcov | coveralls",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "husky && install-peerdeps @wfcd/eslint-config@latest -S",
    "prepublishOnly": "npm run build:types",
    "test": "c8 mocha"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/chai": "^5.0.0",
    "c8": "^11.0.0",
    "chai": "^6.0.1",
    "chai-json-equal": "^0.0.1",
    "coveralls": "^3.1.0",
    "husky": "^9.0.11",
    "install-peerdeps": "^3.0.3",
    "lint-staged": "^16.0.0",
    "mocha": "^11.0.1",
    "mocha-minimalist-reporter": "1.1.0",
    "tsdown": "^0.21.7",
    "tsx": "4.21.0",
    "typedoc": "0.28.18",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@wfcd/items": ">=1.1270.666",
    "warframe-worldstate-data": "^3.0.1"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "publishConfig": {
    "provenance": true
  }
}
