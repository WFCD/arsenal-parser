{
  "exclude": ["docs", "coverage", "node_modules"],
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["chai", "mocha"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
